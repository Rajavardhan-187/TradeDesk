# TradeDesk — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ───────────────────────────────────────────────────────────────
# Your Supabase project URL (from Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Your Supabase anon/public key (safe to expose — protected by RLS)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Groq AI ────────────────────────────────────────────────────────────────
# Platform Groq key — used by the Netlify serverless function for all users.
# Get yours free at https://console.groq.com → API Keys → Create API Key
# In LOCAL dev, set this here. In PRODUCTION, set it in Netlify env vars.
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# ─── Admin ──────────────────────────────────────────────────────────────────
# Email address that gets auto-Pro access (owner/admin)
# Set in index.html as window.__ADMIN_EMAIL in production
VITE_ADMIN_EMAIL=your@email.com
